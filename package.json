{
  "name": "n8n-nodes-searxng-search",
  "version": "0.6.0",
  "description": "n8n community node for SearXNG Search with AI agent support",
  "keywords": [
    "n8n-community-node-package",
    "searxng",
    "msoukhomlinov",
    "search",
    "search-engine",
    "n8n",
    "ai",
    "ai-agent"
  ],
  "license": "MIT",
  "homepage": "https://github.com/msoukhomlinov/n8n-nodes-searxng-search#readme",
  "bugs": {
    "url": "https://github.com/msoukhomlinov/n8n-nodes-searxng-search/issues"
  },
  "author": {
    "name": "Max Soukhomlinov",
    "email": "maxs@intellectit.com.au"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msoukhomlinov/n8n-nodes-searxng-search.git"
  },
  "engines": {
    "node": ">=20.15",
    "pnpm": ">=9.1"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf dist",
    "build": "pnpm clean && tsc -p tsconfig.build.json && gulp build:icons",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "bump": "npx standard-version",
    "prepublishOnly": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SearxngApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Searxng/Searxng.node.js",
      "dist/nodes/Searxng/SearxngAiTools.node.js"
    ]
  },
  "devDependencies": {
    "@langchain/core": "*",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "jest": "30.3.0",
    "n8n-workflow": "1.68.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.3",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "^5.7.2",
    "zod": "*"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "eslintIgnore": [
    "node_modules",
    ".DS_Store",
    ".tmp",
    "tmp",
    "dist",
    "npm-debug.log*",
    "yarn.lock",
    ".vscode/launch.json"
  ]
}
